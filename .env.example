# Postgres connection (Neon pooled URL in prod, local Postgres/Docker in dev)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/openlog?schema=public"

# Direct (non-pooled) connection for `prisma migrate` — only needed in prod
# where DATABASE_URL is a pooled (-pooler) Neon URL. Leave unset in dev.
# DIRECT_URL=""

# Blob storage backend: "fs" (local dev, writes under .data/) or "r2" (Cloudflare R2)
BLOB_BACKEND=fs

# Bearer token required by POST /api/ingest
INGEST_TOKEN=dev-ingest-token

# Cloudflare R2 (only required when BLOB_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
